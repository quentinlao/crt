{
  "name": "crud-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "yarn vite --port 3000",
    "build": "yarn tsc -b && yarn vite build",
    "preview": "yarn vite preview --port 3000",
    "lint": "yarn eslint . --ext .ts,.tsx",
    "lint:fix": "yarn eslint . --ext .ts,.tsx --fix",
    "test": "yarn vitest",
    "test:ui": "yarn vitest --ui",
    "test:coverage": "yarn vitest run --coverage",
    "typecheck": "yarn tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.71.5",
    "@tanstack/react-query-devtools": "^5.71.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "axios": "^1.8.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vitest": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/react": "^18.3.20",
    "@types/react-dom": "18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.1.1",
    "@vitest/ui": "3.1.1",
    "eslint": "^9.21.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.1.5",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.5"
  },
  "packageManager": "yarn@4.8.1"
}
